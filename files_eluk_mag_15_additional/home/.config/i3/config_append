


#// Additional config for Eluktronic Mag-15 laptops

# cbatticon
exec --no-startup-id cbatticon -n

# brightness keys
bindsym XF86MonBrightnessUp exec --no-startup-id xbacklight -fps 20 -inc 10
bindsym XF86MonBrightnessDown exec --no-startup-id xbacklight -fps 20 -inc -10

# volumeicon hackery
exec "~/.config/volumeicon/start.sh"

